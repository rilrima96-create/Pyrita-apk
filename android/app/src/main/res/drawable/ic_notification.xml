<?xml version="1.0" encoding="utf-8"?>
<!--
    Notification small icon для Pyrita VpnService.

    Android требования к notification status bar icon:
      - Только white-on-transparent (monochrome)
      - Простая силуэт-форма (24dp viewport)
      - Adaptive icons / coloured PNG отображаются как белый квадрат

    Это силуэт логомарка Pyrita — 7-куба isometric cluster из
    pyrita-design-system/.../logo-mark.svg (3 верхних + центральный core
    + 3 нижних). Каждый куб = hexagonal silhouette (top of cube
    проецируется в шестиугольник в изометрии). Координаты scaled из
    viewBox 0 0 96 96 → 24×24 (× 0.25). Все 7 hexagon'ов залиты белым
    в едином path — Android применяет tint, рендерит чисто-белым в
    status bar / lockscreen.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <path
        android:fillColor="#FFFFFFFF"
        android:fillType="nonZero"
        android:pathData="M10,4 L14,5.5 L14,8.5 L10,10 L6,8.5 L6,5.5 Z
                          M5,7.5 L9,9 L9,12 L5,13.5 L1,12 L1,9 Z
                          M19,7.5 L23,9 L23,12 L19,13.5 L15,12 L15,9 Z
                          M12,10 L14.5,11 L14.5,13 L12,14 L9.5,13 L9.5,11 Z
                          M7,13 L11,14.5 L11,18 L7,20 L3,18 L3,14.5 Z
                          M12,14.5 L16,16 L16,19 L12,21 L8,19 L8,16 Z
                          M17,13 L21,14.5 L21,18 L17,20 L13,18 L13,14.5 Z" />
</vector>
