<?xml version="1.0" encoding="utf-8"?>
<!--
    Notification small icon для Pyrita VpnService.

    Android требования к notification status bar icon:
      - Только white-on-transparent (monochrome)
      - Простая силуэт-форма (24dp viewport)
      - Adaptive icons / coloured PNG отображаются как белый квадрат

    Это spark — 4-point sparkle из бренд-системы Pyrita (см.
    pyrita-design-system/project/assets/spark.svg). Single-path shape
    которая чисто рендерится белым в status bar / lockscreen.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- 4-point sparkle: верх/низ/лево/право с диагональными inset'ами. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12,1 L13.4,10.6 L23,12 L13.4,13.4 L12,23 L10.6,13.4 L1,12 L10.6,10.6 Z" />
</vector>
