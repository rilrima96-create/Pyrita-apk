<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Базовый интернет — нужен для коммуникации с api.pyrita.com -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Foreground service permissions для long-running VPN соединения.
        Android 14+ (SDK 34+) требует matching FOREGROUND_SERVICE_* permission
        под объявленный foregroundServiceType сервиса.

        flutter_v2ray_client объявляет свой V2rayVPNService с
        foregroundServiceType="specialUse" (см. plugin AndroidManifest).
        Android 16 (SDK 36) делает это строгим требованием: если permission
        отсутствует → SecurityException при startForeground() → краш
        plugin's worker process (отдельный :RunSoLibV2RayDaemon).

        FOREGROUND_SERVICE_SYSTEM_EXEMPTED оставляем как fallback на
        случай downgrade plugin'а на старую версию.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SYSTEM_EXEMPTED" />

    <!--
        POST_NOTIFICATIONS — для Android 13+ нужно явно запрашивать
        permission на показ уведомлений. VpnService persistent-notification
        обязателен по Android-rules.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        REQUEST_INSTALL_PACKAGES — Android 8+ требует permission'а чтобы
        приложение могло trigger'ить установку APK через ACTION_VIEW
        intent. Используется UpdateService для in-app update flow
        (Settings → «Обновить приложение»). При первом install'е Android
        покажет system dialog «Allow Pyrita to install unknown apps?» —
        юзер должен accept'нуть один раз.
    -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />

    <application
        android:label="Pyrita"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher"
        android:enableOnBackInvokedCallback="true"
        android:extractNativeLibs="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Flutter normal theme после splash'а -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Phase C: тут будет VpnService declaration:
            <service android:name=".PyritaVpnService"
                android:foregroundServiceType="systemExempted"
                android:exported="false"
                android:permission="android.permission.BIND_VPN_SERVICE">
                <intent-filter>
                    <action android:name="android.net.VpnService"/>
                </intent-filter>
            </service>
        -->

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!--
            FileProvider для in-app update flow. Authority должна совпадать
            с MainActivity.kt FILE_PROVIDER_AUTHORITY. exported=false +
            grantUriPermissions=true — Android требует это для security:
            content URI's grant'ятся только тем activity'ям которые получают
            intent (package installer в нашем случае).

            Заменяет open_filex's FileProvider (на Android 14+ Samsung One
            UI его install intent silent-reject'ил). Native intent в
            MainActivity.installApk использует этот provider.
        -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.pyrita.pyrita_app.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/pyrita_file_paths" />
        </provider>
    </application>

    <!--
        Required для Flutter 3+: queries для PackageManager-resolution
        (нужно url_launcher / image_picker когда добавим).
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>
</manifest>
