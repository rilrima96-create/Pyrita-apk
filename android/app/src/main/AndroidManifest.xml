<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Базовый интернет — нужен для коммуникации с api.pyrita.com -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!--
        Foreground service permissions — нужны для long-running VPN
        соединения (Phase C). Android 14+ требует FOREGROUND_SERVICE_TYPE.
        Пока в Phase A не используется но лучше задекларировать заранее,
        чтобы не падал build когда добавим VpnService.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SYSTEM_EXEMPTED" />

    <!--
        POST_NOTIFICATIONS — для Android 13+ нужно явно запрашивать
        permission на показ уведомлений. VpnService persistent-notification
        обязателен по Android-rules.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:label="Pyrita"
        android:name="${applicationName}"
        android:enableOnBackInvokedCallback="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

            <!-- Flutter normal theme после splash'а -->
            <meta-data
                android:name="io.flutter.embedding.android.NormalTheme"
                android:resource="@style/NormalTheme" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!--
            Phase C: тут будет VpnService declaration:
            <service android:name=".PyritaVpnService"
                android:foregroundServiceType="systemExempted"
                android:exported="false"
                android:permission="android.permission.BIND_VPN_SERVICE">
                <intent-filter>
                    <action android:name="android.net.VpnService"/>
                </intent-filter>
            </service>
        -->

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>

    <!--
        Required для Flutter 3+: queries для PackageManager-resolution
        (нужно url_launcher / image_picker когда добавим).
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT" />
            <data android:mimeType="text/plain" />
        </intent>
    </queries>
</manifest>
